# Supabase (equipo)
# Project Settings -> API -> Project URL. Usar la URL base, sin /rest/v1.
SUPABASE_URL=https://tu-proyecto.supabase.co

# Project Settings -> API -> Publishable key. No usar service_role/secret key.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Proyecto compartido que la app crea/selecciona al iniciar sesion.
SUPABASE_DEFAULT_PROJECT_SLUG=buglens-default
SUPABASE_DEFAULT_PROJECT_NAME=buglens

# Opcional: UUID de una fila public.projects. Normalmente lo guarda la UI.
SUPABASE_ACTIVE_PROJECT_ID=

# LLM local
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_VISION_MODEL=qwen2.5vl:7b
OLLAMA_BASE_URL=http://localhost:11434

# Rendimiento opcional
LLM_PERFORMANCE_MODE=gpu
# LLM_CONCURRENCY=1
# OLLAMA_TIMEOUT_MS=240000

# Google Docs via OAuth2 (opcional; la sesion de navegador no lo necesita)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Rutas opcionales si los binarios no estan en ubicaciones estandar
# OLLAMA_BIN=C:\Users\tu-usuario\AppData\Local\Programs\Ollama\ollama.exe
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Agente externo opcional
EXTERNAL_AGENT_COMMAND=
EXTERNAL_AGENT_TIMEOUT_MS=1200000
EXTERNAL_AGENT_WORKING_DIRECTORY=
